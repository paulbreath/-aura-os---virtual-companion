# VITE_DEEPSEEK_API_KEY: Required for DeepSeek API calls when user is in China.
VITE_DEEPSEEK_API_KEY=""

# VITE_XAI_API_KEY: Optional. Use X.AI (Grok) models.
VITE_XAI_API_KEY=""

# VITE_OPENROUTER_API_KEY: Required for OpenRouter API calls (includes free models like Dolphin Mistral).
VITE_OPENROUTER_API_KEY=""

# VITE_STABILITY_API_KEY: Optional. Use Stability AI for higher quality character image generation.
VITE_STABILITY_API_KEY=""

# VITE_FAL_API_KEY: Optional. Use FAL.AI for image and video generation (high quality, fast).
VITE_FAL_API_KEY=""

# VITE_AZURE_SPEECH_KEY: Optional. Use Azure Speech TTS (supports China regions, CORS friendly).
VITE_AZURE_SPEECH_KEY=""
VITE_AZURE_SPEECH_REGION="chinaeast2"  # or "eastasia", "southeastasia", "chinanorth2", etc.

# VITE_ELEVENLABS_API_KEY: Required for TTS fallback when user is in China or Gemini quota is exceeded.
VITE_ELEVENLABS_API_KEY=""